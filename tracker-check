#!/usr/bin/env python3
import argparse
import sys
import os
import logging
from scrapeer import Scraper

# Mute the verbose scrapeer INFO/ERROR logs so your terminal stays clean
logging.getLogger('scrapeer.scraper').setLevel(logging.CRITICAL)

def check_hash_against_trackers(info_hash, tracker_urls):
    print(f"Checking info hash: {info_hash}\n")
    print("-" * 50)
    
    for tracker in tracker_urls:
        # Create a fresh scraper for every single tracker to prevent ghost errors
        scraper = Scraper()
        
        print(f"Querying: {tracker}")
        
        # We query them one by one to see individual tracker responses
        results = scraper.scrape(hashes=[info_hash], trackers=[tracker], timeout=3)
        
        # Scrapeer aggregates results by info hash
        data = results.get(info_hash)
        
        if data:
            print(f"  ✅ SUCCESS: Hash known!")
            print(f"     Seeders: {data['seeders']} | Leechers: {data['leechers']} | Completed: {data['completed']}")
        else:
            print("  ❌ FAILED: Hash not found or tracker didn't respond.")
            
            # Moved inside the failure block so it only checks errors if it actually failed
            if scraper.has_errors():
                # Get the most recent error
                error_msg = scraper.get_errors()[-1]
                print(f"     Error Info: {error_msg}")
            
        print("-" * 50)

def main():
    # Set up command-line arguments
    parser = argparse.ArgumentParser(description="Check a torrent info hash against a list of trackers from a file.")
    parser.add_argument("-H", "--hash", required=True, help="The 40-character hex info hash of the torrent.")
    parser.add_argument("-f", "--file", required=True, help="Path to the text file containing trackers (one per line).")
    
    args = parser.parse_args()
    info_hash = args.hash.lower()
    
    # Basic validation
    if len(info_hash) != 40:
        print(f"Warning: Info hash '{info_hash}' is not 40 characters long. Standard BitTorrent hashes are 40-character hex strings.")
    
    if not os.path.isfile(args.file):
        print(f"Error: The file '{args.file}' does not exist or cannot be read.")
        sys.exit(1)

    # Read the trackers from the file
    trackers = []
    with open(args.file, 'r', encoding='utf-8') as f:
        for line in f:
            tracker = line.strip()
            # Ignore empty lines or lines that start with a '#' (comments)
            if tracker and not tracker.startswith('#'):
                trackers.append(tracker)

    if not trackers:
        print(f"Error: No valid trackers found in '{args.file}'.")
        sys.exit(1)

    # Run the scraper
    check_hash_against_trackers(info_hash, trackers)

if __name__ == "__main__":
    main()
